{
  "cleanUrls": true,
  "trailingSlash": false,
  "outputDirectory": "public",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "server/**",
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
